"""
Unified Communication X (UCX) is an award winning, optimized production proven-communication framework for modern, high-bandwidth and low-latency networks.
"""

load("@//third_party/openucx:native_ucx_build.bzl", "native_ucx_build")
load("@//third_party/openucx:utils.bzl", "file_filter", "file_prefix_filter")
load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
    visibility = ["//visibility:public"],
)

exports_files([
    "BUILD.bazel",
    "build_ucx.sh",
])

config_setting(
    name = "debug_build",
    values = {"compilation_mode": "dbg"},
)

out_binaries = []

out_shared_libs = [
    "libucm.so",
    "libucm.so.0",
    "libucm.so.0.0.0",
    "libucp.so",
    "libucp.so.0",
    "libucp.so.0.0.0",
    "libucs_signal.so",
    "libucs_signal.so.0",
    "libucs_signal.so.0.0.0",
    "libucs.so",
    "libucs.so.0",
    "libucs.so.0.0.0",
    "libuct.so",
    "libuct.so.0",
    "libuct.so.0.0.0",
    "libuct_cma.so",
    "libuct_cma.so.0",
    "libuct_cma.so.0.0.0",
    "libuct_ib.so",
    "libuct_ib.so.0",
    "libuct_ib.so.0.0.0",
    "libuct_ib_mlx5.so",
    "libuct_ib_mlx5.so.0",
    "libuct_ib_mlx5.so.0.0.0",
    "libuct_rdmacm.so",
    "libuct_rdmacm.so.0",
    "libuct_rdmacm.so.0.0.0",
    "libuct_knem.so",
    "libuct_knem.so.0",
    "libuct_knem.so.0.0.0",
    "libuct_xpmem.so",
    "libuct_xpmem.so.0",
    "libuct_xpmem.so.0.0.0",
    "libxpmem.so",
    "libgdrapi.so",
]

cuda_out_shared_libs = [
    "libucm_cuda.so",
    "libucm_cuda.so.0",
    "libucm_cuda.so.0.0.0",
    "libuct_cuda.so",
    "libuct_cuda.so.0",
    "libuct_cuda.so.0.0.0",
]

out_static_libs = [
    "libucm.a",
    "libucp.a",
    "libucs_signal.a",
    "libucs.a",
    "libuct.a",
    "libuct_cma.a",
    "libuct_ib.a",
    "libuct_ib_mlx5.a",
]

cuda_out_static_libs = [
    "libucm_cuda.a",
    "libuct_cuda.a",
]

base_outs = (
    ["lib/" + lib for lib in out_shared_libs] +
    ["lib/" + lib for lib in out_static_libs] +
    ["bin/" + bin for bin in out_binaries] + [
        "include/ucp/api/ucp_version.h",
        "include/uct/api/version.h",
    ]
)

native_ucx_build(
    name = "ucx_build",
    srcs = [
        ":all_srcs",
        "@gdrcopy//:all_srcs",
        "@gdrcopy//:headers",
        "@infiniband_diags//:headers",
        "@knem//:headers",
        "@libfuse//:headers",
        "@libfuse_libs//:libs",
        "@numactl//:headers",
        "@numactl_libs//:libs",
        "@rdma_core//:headers",
        "@rdma_core_libs//:libs",
        "@xpmem//:all_srcs",
        "@xpmem//:headers",
    ] + select({
        "@rules_ml_toolchain//common:is_cuda_enabled": [
            "@local_config_cuda//cuda:cuda_driver",
            "@local_config_cuda//cuda:cuda_headers",
            "@local_config_cuda//cuda:cudart",
            "@local_config_cuda//cuda:cudart_headers",
            "@local_config_cuda//cuda:cudart_static",
            "@local_config_cuda//cuda:nvml_headers",
        ],
        "//conditions:default": [],
    }),
    outs = base_outs,
    configure_options = [
        "--with-avx",
        "--with-march",
        "--enable-cma",
        "--with-rc",
        "--with-ud",
        "--with-dc",
        "--with-ib-hw-tm",
        "--with-dm",
        "--enable-tuning",
        "--with-mad=yes",
        "--with-gdrcopy=yes",
        "--with-mlx5=yes",
        "--with-rdmacm=yes",
        "--with-knem=yes",
        "--with-xpmem=yes",
        "--with-java=no",
        "--with-go=no",
    ],
    cuda_outs = (
        ["lib/" + lib for lib in cuda_out_shared_libs] +
        ["lib/" + lib for lib in cuda_out_static_libs]
    ),
    debug_options = [
        "--enable-debug",
        "--enable-debug-data",
        "--enable-logging",
        "--enable-params-check",
        "--enable-compiler-opt=0",
    ],
    opt_options = [
        "--disable-debug",
        "--disable-debug-data",
        "--disable-assertions",
        "--disable-logging",
        "--disable-params-check",
        "--without-valgrind",
        "--enable-optimizations",
        "--enable-compiler-opt=3",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "ucx_gen_dir",
    srcs = [":ucx_build"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "ucx_libs_all",
    srcs = [":ucx_build"],
    visibility = ["//visibility:public"],
)

file_filter(
    name = "ucx_shared_libs",
    srcs = [":ucx_build"],
    extensions = [
        ".so",
        ".so.0",
        ".so.0.0.0",
    ],
    visibility = ["//visibility:public"],
)

# UCX core libraries: linked at build time as DT_NEEDED.
file_prefix_filter(
    name = "ucx_core_shared_libs",
    srcs = [":ucx_shared_libs"],
    exclude_prefixes = [
        "libuct_",
        "libucm_",
    ],
    prefixes = [
        "libucm.so",
        "libucp.so",
        "libucs_signal.so",
        "libucs.so",
        "libuct.so",
    ],
    visibility = ["//visibility:public"],
)

# UCX transport plugins: loaded via dlopen at runtime.
# UCX scans <libucs_dir>/ucx/ for these modules.
file_prefix_filter(
    name = "ucx_transport_shared_libs",
    srcs = [":ucx_shared_libs"],
    prefixes = [
        "libuct_cma",
        "libuct_ib",
        "libuct_rdmacm",
        "libuct_knem",
        "libuct_xpmem",
        "libuct_cuda",
        "libucm_cuda",
        "libxpmem",
        "libgdrapi",
    ],
    visibility = ["//visibility:public"],
)

file_filter(
    name = "ucx_static_libs",
    srcs = [":ucx_build"],
    extensions = [".a"],
    visibility = ["//visibility:public"],
)

file_filter(
    name = "_ucx_header_includes",
    srcs = [":ucx_build"],
    extensions = [".h"],
)

cc_library(
    name = "ucx_headers",
    hdrs = [
        ":_ucx_header_includes",
    ] + glob([
        "src/**/*.h",
        "src/**/*.hpp",
        "src/**/*.def",
    ]),
    includes = [
        "include",
        "src",
    ],
    visibility = ["//visibility:public"],
)

# Core shared libs only (link-time dependencies).
# Transport plugins are NOT included here; they are loaded via dlopen
# by UCX's module loader at runtime, enabling graceful degradation
# on machines without specific hardware (IB, XPMEM, CUDA, etc.).
cc_library(
    name = "ucx_prebuilt_shared",
    srcs = [
        ":ucx_core_shared_libs",
    ],
    linkopts = [
        "-Wl,--as-needed",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "@numactl_libs//:cc_libs",
    ],
)

# Static libs only
cc_library(
    name = "ucx_prebuilt_static",
    srcs = [
        ":ucx_static_libs",
    ],
    linkopts = [
        "-Wl,--as-needed",
    ],
    visibility = ["//visibility:public"],
)

# Backward compatibility alias (points to shared by default to avoid accidental static linking issues in dynamic builds)
# But strictly speaking, "prebuilt" implied everything before.
# To be safe for mixed usage, we alias to shared, as static users should use static targets.
# However, existing targets like `ucs` use `linkstatic = False`, so they want shared.
alias(
    name = "ucx_prebuilt",
    actual = ":ucx_prebuilt_shared",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "ucm",
    includes = ["ucx/include"],
    linkopts = [
        "-Wl,--as-needed",
    ],
    linkstatic = False,
    deps = [
        ":ucx_headers",
    ],
)

cc_library(
    name = "ucm_static",
    includes = ["ucx/include"],
    linkopts = [
        "-Wl,--as-needed",
    ],
    linkstatic = True,
    deps = [
        ":ucx_headers",
    ],
)

cc_library(
    name = "ucs_signal",
    linkstatic = False,
    deps = [
        ":ucx_headers",
    ],
)

cc_library(
    name = "ucs_signal_static",
    linkstatic = True,
    deps = [
        ":ucx_headers",
    ],
)

cc_library(
    name = "ucs",
    linkopts = [
        "-Wl,--undefined=ucs_init,--as-needed",
        "-ldl",
        "-lrt",
        "-lm",
        "-lpthread",
    ],
    linkstatic = False,
    visibility = ["@ucc//:__pkg__"],
    deps = [
        ":ucm",
        ":ucs_signal",
        ":ucx_headers",
        ":ucx_prebuilt_shared",
    ],
)

cc_library(
    name = "ucs_static",
    linkopts = [
        "-Wl,--undefined=ucs_init,--as-needed",
        "-ldl",
        "-lrt",
        "-lm",
        "-lpthread",
    ],
    linkstatic = True,
    visibility = ["@ucc//:__pkg__"],
    deps = [
        ":ucm_static",
        ":ucs_signal_static",
        ":ucx_headers",
        ":ucx_prebuilt_static",
    ],
)

cc_library(
    name = "uct",
    linkopts = [
        "-Wl,--undefined=uct_init,--as-needed",
    ],
    linkstatic = False,
    deps = [
        ":ucs",
        ":ucx_headers",
        ":ucx_prebuilt_shared",
    ],
)

cc_library(
    name = "uct_static",
    linkopts = [
        "-Wl,--undefined=uct_init,--as-needed",
    ],
    linkstatic = True,
    deps = [
        ":ucs_static",
        ":ucx_headers",
        ":ucx_prebuilt_static",
    ],
)

cc_library(
    name = "ucp",
    linkopts = [
        "-Wl,--undefined=ucp_global_init,--as-needed",
    ],
    linkstatic = False,
    deps = [
        ":ucx_headers",
        ":ucx_prebuilt_shared",
    ],
)

cc_library(
    name = "ucp_static",
    linkopts = [
        "-Wl,--undefined=ucp_global_init,--as-needed",
    ],
    linkstatic = True,
    deps = [
        ":ucx_headers",
        ":ucx_prebuilt_static",
    ],
)

cc_library(
    name = "ucx_runtime",
    linkstatic = False,
    visibility = ["//visibility:public"],
    deps = [
        ":ucp",
        ":ucs",
        ":uct",
        ":ucx_headers",
    ],
)

cc_library(
    name = "ucx_runtime_static",
    linkstatic = True,
    visibility = ["//visibility:public"],
    deps = [
        ":ucp_static",
        ":ucs_static",
        ":uct_static",
        ":ucx_headers",
    ],
)

alias(
    name = "ucx",
    actual = ":ucx_runtime",
    visibility = ["//visibility:public"],
)
